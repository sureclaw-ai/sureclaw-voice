# Secrets — never commit. gateway.sh sources .env to populate OPENAI_API_KEY.
.env
.env.*

# Local OpenClaw runtime state (OPENCLAW_STATE_DIR) — SQLite, workspace, logs.
.state/

# Vendored test-rig tooling (qmd memory backend). package.json + lockfile are
# committed; the installed tree is not.
node_modules/

# Stray gateway log files if you redirect output here.
*.log

# Local overrides to the config (secrets, custom ports, etc.).
openclaw.local.json

# Runtime snapshot of the last config the gateway loaded successfully.
openclaw.json.last-good
