{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": { "mode": "none" },
    "controlUi": {
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "agents": {
    "defaults": {
      "model": "openai/gpt-5.4",
      "thinkingDefault": "medium",
      "memorySearch": {
        "sources": ["memory", "sessions"],
        "experimental": { "sessionMemory": true }
      }
    }
  },
  "plugins": {
    "load": {
      "paths": ["${SURECLAW_VOICE_ROOT}"]
    },
    "entries": {
      "sureclaw-voice": {
        "enabled": true,
        "config": {
          "realtime": {
            "enabled": true,
            "provider": "openai",
            "model": "gpt-realtime-2",
            "voice": "alloy",
            "toolPolicy": "owner",
            "consultPolicy": "always",
            "agentContext": {
              "enabled": true,
              "includeIdentity": true,
              "includeWorkspaceFiles": true,
              "files": ["SOUL.md", "IDENTITY.md", "USER.md"],
              "maxChars": 6000
            },
            "fastContext": {
              "enabled": true,
              "timeoutMs": 800,
              "maxResults": 3,
              "sources": ["memory", "sessions"]
            },
            "providers": {
              "openai": {
                "apiKey": "${OPENAI_API_KEY}"
              }
            }
          },
          "webapp": {
            "path": "/voice",
            "name": "SureClaw Voice"
          }
        }
      }
    }
  }
}
